root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sh,tmux}]
indent_style = tab

[*.md]
indent_style = space
indent_size = 2
# trailing whitespace is significant in Markdown (two spaces = hard line break)
trim_trailing_whitespace = false
